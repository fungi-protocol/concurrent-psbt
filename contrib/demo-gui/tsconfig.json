{
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "declaration": true,
    "lib": ["DOM", "ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noImplicitAny": false,
    "noEmitOnError": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": false,
    "target": "ES2022"
  },
  "include": ["src/**/*.ts"]
}
